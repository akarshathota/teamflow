[
  {
    "name": "task_assigned",
    "language": "en_US",
    "category": "UTILITY",
    "components": [
      { "type": "HEADER", "format": "TEXT", "text": "New task assigned" },
      {
        "type": "BODY",
        "text": "Hi {{1}}, {{2}} has assigned you a task:\n\n📋 {{3}}\n🏷 Priority: {{4}}\n📅 Due: {{5}}\n\nTap below to open TeamFlow and update its status.",
        "example": { "body_text": [["Ravi", "Chandu", "Fix the 2nd-floor projector", "High", "25 Jul 2026"]] }
      },
      { "type": "FOOTER", "text": "TeamFlow" },
      { "type": "BUTTONS", "buttons": [{ "type": "URL", "text": "Open task", "url": "https://athota.work/jhps" }] }
    ]
  },
  {
    "name": "task_reminder",
    "language": "en_US",
    "category": "UTILITY",
    "components": [
      { "type": "HEADER", "format": "TEXT", "text": "Task reminder" },
      {
        "type": "BODY",
        "text": "Hi {{1}}, this is a reminder about a task that is {{2}}:\n\n📋 {{3}}\n📅 Due: {{4}}\n\nPlease update its status in TeamFlow.",
        "example": { "body_text": [["Ravi", "overdue", "Terrace waterproofing", "20 Jul 2026"]] }
      },
      { "type": "FOOTER", "text": "TeamFlow" },
      { "type": "BUTTONS", "buttons": [{ "type": "URL", "text": "Open task", "url": "https://athota.work/jhps" }] }
    ]
  },
  {
