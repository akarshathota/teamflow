    "components": [
      { "type": "HEADER", "format": "TEXT", "text": "We received your request" },
      {
        "type": "BODY",
        "text": "Hi {{1}}, your {{2}} has been logged as ticket #{{3}}:\n\n\"{{4}}\"\n\nYou'll be notified when it is assigned and again when it is resolved.",
        "example": { "body_text": [["Ravi", "maintenance report", "42", "Broken chair in Lab 10B"]] }
      },
      { "type": "FOOTER", "text": "TeamFlow" }
    ]
  },
